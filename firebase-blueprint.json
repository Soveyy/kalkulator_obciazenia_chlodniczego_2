{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "User's saved project configuration and data",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "date": { "type": "string" },
        "data": { "type": "string", "description": "JSON stringified project data" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "date", "data", "userId", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "User's collection of saved projects."
    }
  }
}
